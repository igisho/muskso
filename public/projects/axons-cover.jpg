<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.1//EN" "http://www.w3.org/TR/xhtml11/DTD/xhtml11.dtd">

<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en">

<head>
    <title>404 Not Found</title>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <style type="text/css">
        /*<![CDATA[*/
        body {
            background-color: #fff;
            font-family: 'Raleway', sans-serif;
            color: #000;
            margin: 0;
        }

        #header {
            background-color: #e8e8e8
        }

        .navbar-header {
            padding-right: 15px;
            padding-left: 15px;
            margin-top: -1px;
            margin-bottom: 85px;
        }

        .navbar {
            border-radius: 0px;
            margin: 0px -15px;
            padding-top: 25px;
            padding-bottom: 25px;
            background-image: url(data:image/png;base64,);
            background-repeat: no-repeat;
            background-position: right bottom;
        }

        .navbar-brand {
            float: left;
            height: 50px;
            padding: 15px 0px 15px 15px;
            font-size: 18px;
            line-height: 20px;
        }

        .navbar {
            position: relative;
            min-height: 50px;
            margin-bottom: 20px;
            border: 1px solid transparent;
        }

        .navbar:after {
            display: table;
            content: " ";
            clear: both;

        }

        .site_logo {
            width: 200%;
            max-width: 300px;
            margin-top: -12px;
            margin-left: -0px;
        }

        .container {
        width: 1024px;
        padding-right: 15px;
        padding-left: 15px;
        margin-right: auto;
        margin-left: auto;
        }

        .textcontainer {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 30vh;
        }

        /*]]>*/
    </style>
</head>

<body>
    <div id="header" style='background:url(data:image/jpeg;base64,
) repeat-x center;'>
        <div class="container">
            <!-- Navigation -->
            <nav class="navbar navbar-inverse  navbar-static-top" role="navigation" style="margin-bottom: 0">
                <div class="navbar-header" style="margin-bottom: 50px;">

                    <a href="/" title="Spectrum Computing" class="navbar-brand"><img
                            src="data:image/svg+xml;base64,"
                            class="site_logo"></a>
                </div>
            </nav>
            <!-- /.navbar-static-side -->
        </div>
    </div>
    <div class="textcontainer">
        <div>
            <h1>404 Not Found</h1>
            <p>Sorry, the page you are looking for is not found.</p>
            <p>It may have been moved or deleted.</p>
            <p>Check the URL and try again or contact the webmaster if you think this is an error.</p>
            <p>Thank you.</p>
        </div>
    </div>
</body>

</html>

